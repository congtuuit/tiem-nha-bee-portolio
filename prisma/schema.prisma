generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model products {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  slug        String   @unique
  description String?
  price       Decimal?
  cover_image String?
  images      Json?    @default("[]")
  created_at  DateTime @default(now()) @db.Timestamptz(6)
}
